DATABASE_URL="postgresql://postgres:password@localhost:5432/supportdesk_test?schema=public"

BETTER_AUTH_SECRET="generate-a-separate-secret-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:4001"

CLIENT_URL="http://localhost:5174"

SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="password123"

# Ports used only by the Playwright-managed webServer instances, kept
# distinct from the normal dev ports (4000 / 5173) so `bun run test:e2e`
# never collides with (or accidentally talks to) a `bun run dev` you already
# have open.
PORT="4001"
VITE_PORT="5174"
VITE_API_PROXY_TARGET="http://localhost:4001"
