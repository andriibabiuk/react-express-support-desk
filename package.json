{
	"name": "react-express-support-desk",
	"private": true,
	"type": "module",
	"workspaces": [
		"client",
		"server"
	],
	"scripts": {
		"dev": "bun run --filter '*' --parallel dev",
		"build": "bun run --filter '*' build",
		"test:e2e:db:reset": "bun run e2e/reset-test-db.ts",
		"test:e2e": "bun run test:e2e:db:reset && playwright test"
	},
	"overrides": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"dotenv": "^17.4.2"
	}
}
